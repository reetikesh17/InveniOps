# Copy to .env for local `npm run dev` outside Docker. Vite only exposes
# vars prefixed with VITE_ to client code (see src/vite-env.d.ts).

# Base URL the frontend uses to reach the backend API. The browser makes
# this request directly (not through the Docker network), so it should
# point at the backend's published host port either way.
VITE_API_BASE_URL=http://localhost:3000
