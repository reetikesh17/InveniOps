# Copy this file to .env and adjust as needed. Defaults below match the
# docker-compose.yml service configuration and work out of the box for
# local development — no edits required to run `make up`.

# ---- Backend runtime ----
NODE_ENV=development
# Port the backend Express server listens on, and the port it's published
# on for the host (http://localhost:<PORT>).
PORT=3000

# ---- PostgreSQL (source of truth: work items, RCA records) ----
# Used both by the postgres container (to create the user/db on first boot)
# and by the backend to build DATABASE_URL below — keep them in sync.
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_password
POSTGRES_DB=ims
# Prisma connection string. Host is "postgres", the compose service name,
# resolvable only from other containers on the ims-network — from the host
# machine use localhost:5432 instead (port 5432 is published for local tools).
DATABASE_URL=postgresql://ims_user:ims_password@postgres:5432/ims

# ---- MongoDB (raw signal audit log) ----
# No auth configured for local dev. Host is "mongo", the compose service
# name — from the host machine use localhost:27017 (published for local
# tools such as mongosh or Compass).
MONGODB_URI=mongodb://mongo:27017/ims

# ---- Redis (dashboard hot-path cache + BullMQ queue backend) ----
# No auth configured for local dev. Host is "redis", the compose service
# name — from the host machine use localhost:6379 (published for redis-cli).
REDIS_URL=redis://redis:6379

# ---- Signal ingestion (POST /api/v1/signals) ----
# Max signals accepted in a single request (single object or array body).
INGESTION_MAX_BATCH_SIZE=500
# Max synthetic signals POST /api/v1/signals/bulk-test can generate in one
# call. That endpoint only exists when NODE_ENV != production.
INGESTION_BULK_TEST_MAX_COUNT=20000

# ---- Rate limiting (token bucket, backed by Redis) ----
# Per-source-IP bucket.
RATE_LIMIT_IP_CAPACITY=50
RATE_LIMIT_IP_REFILL_PER_SECOND=20
# Global bucket, shared across all replicas via Redis.
RATE_LIMIT_GLOBAL_CAPACITY=5000
RATE_LIMIT_GLOBAL_REFILL_PER_SECOND=2000

# ---- In-memory ingestion buffer (src/services/ingestion/buffer.ts) ----
# See docs/backpressure.md for the full design and why these numbers.
# Total signal slots, shared across all four severities.
BUFFER_CAPACITY=20000
# Fill fraction (of BUFFER_CAPACITY) at which shedding begins / ends.
BUFFER_HIGH_WATER_MARK_FRACTION=0.8
BUFFER_LOW_WATER_MARK_FRACTION=0.5
# Fraction of BUFFER_CAPACITY each severity may occupy once shedding is
# active (P0 has none — it's never ceiling-shed). Must satisfy P3 < P2 < P1.
BUFFER_SHED_CEILING_P1_FRACTION=0.7
BUFFER_SHED_CEILING_P2_FRACTION=0.4
BUFFER_SHED_CEILING_P3_FRACTION=0.15
# Consumer drain loop: batch size and tick interval.
BUFFER_DRAIN_BATCH_SIZE=200
BUFFER_DRAIN_INTERVAL_MS=50
# Max time the shutdown hook spends draining the buffer before giving up.
BUFFER_SHUTDOWN_DRAIN_TIMEOUT_MS=10000

# ---- Signal debouncing (src/services/ingestion/debouncer.ts) ----
# Spec default: 100 signals for the same component within 10s -> 1 work item.
DEBOUNCE_WINDOW_SECONDS=10
DEBOUNCE_THRESHOLD=100
# Creation lock TTL, and how long a signal waits for another worker's
# in-flight resolution before falling back to resolving independently.
DEBOUNCE_LOCK_TTL_MS=5000
DEBOUNCE_LOCK_WAIT_TIMEOUT_MS=1000
DEBOUNCE_LOCK_POLL_INTERVAL_MS=20

# ---- Frontend ----
# The browser calls this directly (not through the Docker network), so it
# points at the backend's published host port regardless of how the
# frontend itself is running (Docker or plain `npm run dev`).
VITE_API_BASE_URL=http://localhost:3000
