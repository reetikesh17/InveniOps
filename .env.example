# Copy this file to .env and adjust as needed. Defaults below match the
# docker-compose.yml service configuration and work out of the box for
# local development — no edits required to run `make up`.

# ---- Backend runtime ----
NODE_ENV=development
# Port the backend Express server listens on, and the port it's published
# on for the host (http://localhost:<PORT>).
PORT=3000

# ---- PostgreSQL (source of truth: work items, RCA records) ----
# Used both by the postgres container (to create the user/db on first boot)
# and by the backend to build DATABASE_URL below — keep them in sync.
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_password
POSTGRES_DB=ims
# Prisma connection string. Host is "postgres", the compose service name,
# resolvable only from other containers on the ims-network — from the host
# machine use localhost:5432 instead (port 5432 is published for local tools).
DATABASE_URL=postgresql://ims_user:ims_password@postgres:5432/ims

# ---- MongoDB (raw signal audit log) ----
# No auth configured for local dev. Host is "mongo", the compose service
# name — from the host machine use localhost:27017 (published for local
# tools such as mongosh or Compass).
MONGODB_URI=mongodb://mongo:27017/ims

# ---- Redis (dashboard hot-path cache + BullMQ queue backend) ----
# No auth configured for local dev. Host is "redis", the compose service
# name — from the host machine use localhost:6379 (published for redis-cli).
REDIS_URL=redis://redis:6379
